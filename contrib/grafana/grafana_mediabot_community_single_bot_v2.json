{
  "title": "Mediabot Community Overview",
  "uid": "mediabot-community-single-v2",
  "tags": [
    "mediabot",
    "prometheus",
    "irc",
    "community"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance_name",
        "label": "Bot",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(mediabot_up, instance_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        }
      },
      {
        "name": "channel",
        "label": "Channel",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(mediabot_channel_lines_in_total, channel)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ],
          "selected": true
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Bot Up",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(mediabot_up{instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "IRC Connected",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(mediabot_irc_connected{instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "DB Connected",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(mediabot_db_connected{instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Managed Channels",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(mediabot_channels_managed{instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(mediabot_uptime_seconds{instance_name=~\"$instance_name\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Lines / min",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(mediabot_channel_lines_in_total{instance_name=~\"$instance_name\",channel=~\"$channel\"}[5m])) * 60",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Public / Private / Partyline Commands / min",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(rate(mediabot_commands_public_total{instance_name=~\"$instance_name\"}[5m])) * 60",
          "legendFormat": "public",
          "refId": "A"
        },
        {
          "expr": "sum(rate(mediabot_commands_private_total{instance_name=~\"$instance_name\"}[5m])) * 60",
          "legendFormat": "private",
          "refId": "B"
        },
        {
          "expr": "sum(rate(mediabot_commands_partyline_total{instance_name=~\"$instance_name\"}[5m])) * 60",
          "legendFormat": "partyline",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Lines / min by Channel",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (channel) (rate(mediabot_channel_lines_in_total{instance_name=~\"$instance_name\",channel=~\"$channel\"}[5m])) * 60",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Commands / min by Channel",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (channel) (rate(mediabot_channel_commands_total{instance_name=~\"$instance_name\",channel=~\"$channel\"}[5m])) * 60)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      }
    },
    {
      "type": "bargauge",
      "title": "Top Commands by Channel",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "expr": "topk(20, sum by (channel, command) (increase(mediabot_channel_commands_by_name_total{instance_name=~\"$instance_name\",channel=~\"$channel\"}[$__range])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      }
    },
    {
      "type": "bargauge",
      "title": "Top Public Commands Global",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "targets": [
        {
          "expr": "topk(15, sum by (command) (increase(mediabot_commands_public_total{instance_name=~\"$instance_name\"}[$__range])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      }
    },
    {
      "type": "timeseries",
      "title": "Operations",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum(increase(mediabot_rehash_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "rehash",
          "refId": "A"
        },
        {
          "expr": "sum(increase(mediabot_restart_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "restart",
          "refId": "B"
        },
        {
          "expr": "sum(increase(mediabot_jump_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "jump",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Auth / Partyline",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum(increase(mediabot_auth_success_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "auth_success",
          "refId": "A"
        },
        {
          "expr": "sum(increase(mediabot_auth_failure_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "auth_failure",
          "refId": "B"
        },
        {
          "expr": "sum(increase(mediabot_partyline_logins_total{instance_name=~\"$instance_name\"}[$__range]))",
          "legendFormat": "partyline_logins",
          "refId": "C"
        },
        {
          "expr": "sum(mediabot_partyline_sessions_current{instance_name=~\"$instance_name\"})",
          "legendFormat": "partyline_sessions",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "table",
      "title": "Build Info",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "mediabot_build_info{instance_name=~\"$instance_name\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}